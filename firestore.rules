rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function email() {
      return request.auth.token.email;
    }

    function isOwner(userId) {
      return signedIn() && uid() == userId;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.role in ["Admin", "admin"]
          || exists(/databases/$(database)/documents/admins/$(uid()))
          || (
            email() != null
            && exists(/databases/$(database)/documents/admins/$(email()))
          )
        );
    }

    function isDriver() {
      return signedIn()
        && (
          request.auth.token.role in ["Driver", "driver"]
          || (
            exists(/databases/$(database)/documents/users/$(uid()))
            && get(/databases/$(database)/documents/users/$(uid())).data.role in ["Driver", "driver"]
          )
        );
    }

    function canCreateOwnDriverProfile(userId) {
      return isOwner(userId)
        && request.resource.data.role in ["Driver", "driver"]
        && !request.resource.data.keys().hasAny(["admin", "Role"]);
    }

    function canUpdateOwnProfile() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "name",
        "displayName",
        "phone",
        "phoneNumber",
        "photoURL",
        "address",
        "fcmToken",
        "notificationSettings",
        "deviceInfo",
        "lastLoginAt",
        "updatedAt"
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || canCreateOwnDriverProfile(userId);
      allow update: if isAdmin() || (isOwner(userId) && canUpdateOwnProfile());
      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /assigned_vehicles/{vehicleId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
    }

    match /vehicles/{vehicleId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /inspections/{inspectionId} {
      allow read: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == uid()
        );

      allow create: if isDriver()
        && request.resource.data.userId == uid();

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == uid()
          && request.resource.data.userId == resource.data.userId
        );

      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read, write: if isAdmin();
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /driverInspectionHistory/{docId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
